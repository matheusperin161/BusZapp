# ─────────────────────────────────────────────
#  BusZapp — variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Segurança
SECRET_KEY=troque-por-uma-chave-secreta-forte

# ── Banco de Dados ──────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
#
# Exemplos:
#   Local:   postgresql://postgres:senha@localhost:5432/buszapp
#   Render:  cole a "Internal Database URL" do painel
#   Supabase: postgresql://postgres:[senha]@db.[ref].supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres:senha@localhost:5432/buszapp

# ── Google Maps / Rastreamento ──────────────
GOOGLE_API_KEY=sua-chave-google-maps

# Coordenadas da rota (Chapecó-SC como padrão)
ROUTE_ORIGIN_LAT=-27.10597
ROUTE_ORIGIN_LON=-52.61336
ROUTE_DEST_LAT=-27.07171
ROUTE_DEST_LON=-52.63635

# ── Ambiente ────────────────────────────────
FLASK_ENV=production
DEBUG=false

# ── E-mail (Gmail SMTP) ──────────────────────
# Crie uma conta Gmail exclusiva para o app
# Gere a senha de app em: myaccount.google.com/apppasswords
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# URL base do app — usada nos links dos e-mails enviados
# Em produção: https://seudominio.com
APP_URL=http://localhost:8080
